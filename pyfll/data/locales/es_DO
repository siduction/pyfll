lang=es
bootlang="lang=es_DO"
def_bootlang="es_DO"
if [ -z "${keyboard}" ]; then
  def_keyboard="latam"
  keyboard="keytable=latam"
fi
if [ -z "${timezone}" ]; then
  def_timezone="America/Santo_Domingo"
  timezone="tz=America/Santo_Domingo"
fi
export def_bootlang
export bootlang
export def_keyboard
export def_timezone
export keyboard
export timezone
