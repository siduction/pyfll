lang=uk
bootlang="lang=uk_UA"
def_bootlang="uk_UA"
if [ -z "${keyboard}" ]; then
  def_keyboard="ua"
  keyboard="keytable=ua"
fi
if [ -z "${timezone}" ]; then
  def_timezone="Europe/Kiev"
  timezone="tz=Europe/Kiev"
fi
export def_bootlang
export bootlang
export def_keyboard
export def_timezone
export keyboard
export timezone
