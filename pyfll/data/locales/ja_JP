lang=ja
bootlang="lang=ja_JP"
def_bootlang="ja_JP"
if [ -z "${keyboard}" ]; then
  def_keyboard="jp"
  keyboard="keytable=jp"
fi
if [ -z "${timezone}" ]; then
  def_timezone="Asia/Tokyo"
  timezone="tz=Asia/Tokyo"
fi
export def_bootlang
export bootlang
export def_keyboard
export def_timezone
export keyboard
export timezone
