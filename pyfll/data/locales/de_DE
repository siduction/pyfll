lang=de
bootlang="lang=de_DE"
def_bootlang="de_DE"
if [ -z "${keyboard}" ]; then
  def_keyboard="de"
  keyboard="keytable=de"
fi
if [ -z "${timezone}" ]; then
  def_timezone="Europe/Berlin"
  timezone="tz=Europe/Berlin"
fi
export def_bootlang
export bootlang
export def_keyboard
export def_timezone
export keyboard
export timezone
