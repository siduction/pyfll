lang=en
bootlang="lang=en_NG"
def_bootlang="en_NG"
if [ -z "${keyboard}" ]; then
  def_keyboard="us"
  keyboard="keytable=us"
fi
if [ -z "${timezone}" ]; then
  def_timezone="Africa/Lagos"
  timezone="tz=Africa/Lagos"
fi
export def_bootlang
export bootlang
export def_keyboard
export def_timezone
export keyboard
export timezone
