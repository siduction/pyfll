lang=de
bootlang="lang=de_CH"
def_bootlang="de_CH"
if [ -z "${keyboard}" ]; then
  def_keyboard="ch"
  keyboard="keytable=ch"
fi
if [ -z "${timezone}" ]; then
  def_timezone="Europe/Zurich"
  timezone="tz=Europe/Zurich"
fi
export def_bootlang
export bootlang
export def_keyboard
export def_timezone
export keyboard
export timezone