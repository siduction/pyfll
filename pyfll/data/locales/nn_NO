lang=nn
bootlang="lang=nn_NO"
def_bootlang="nn_NO"
if [ -z "${keyboard}" ]; then
  def_keyboard="no"
  keyboard="keytable=no"
fi
if [ -z "${timezone}" ]; then
  def_timezone="Europe/Oslo"
  timezone="tz=Europe/Oslo"
fi
export def_bootlang
export bootlang
export def_keyboard
export def_timezone
export keyboard
export timezone
