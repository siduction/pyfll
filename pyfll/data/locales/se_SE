lang=se
bootlang="lang=se_SE"
def_bootlang="se_SE"
if [ -z "${keyboard}" ]; then
  def_keyboard="se"
  keyboard="keytable=se"
fi
if [ -z "${timezone}" ]; then
  def_timezone="Europe/Stockholm"
  timezone="tz=Europe/Stockholm"
fi
export def_bootlang
export bootlang
export def_keyboard
export def_timezone
export keyboard
export timezone
