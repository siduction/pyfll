lang=zh
bootlang="lang=zh_CN"
def_bootlang="zh_CN"
if [ -z "${keyboard}" ]; then
  def_keyboard="us"
  keyboard="keytable=us"
fi
if [ -z "${timezone}" ]; then
  def_timezone="Asia/Shaghai"
  timezone="tz=Asia/Shaghai"
fi
export def_bootlang
export bootlang
export def_keyboard
export def_timezone
export keyboard
export timezone
