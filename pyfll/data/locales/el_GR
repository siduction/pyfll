lang=el
bootlang="lang=el_GR"
def_bootlang="el_GR"
if [ -z "${keyboard}" ]; then
  def_keyboard="gr"
  keyboard="keytable=gr"
fi
if [ -z "${timezone}" ]; then
  def_timezone="Europe/Athens"
  timezone="tz=Europe/Athens"
fi
export def_bootlang
export bootlang
export def_keyboard
export def_timezone
export keyboard
export timezone
