lang=be
bootlang="lang=be_BY"
def_bootlang="be_BY"
if [ -z "${keyboard}" ]; then
  def_keyboard="by"
  keyboard="keytable=by"
fi
if [ -z "${timezone}" ]; then
  def_timezone="Europe/Minsk"
  timezone="tz=Europe/Minsk"
fi
export def_bootlang
export bootlang
export def_keyboard
export def_timezone
export keyboard
export timezone