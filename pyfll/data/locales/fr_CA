lang=fr
bootlang="lang=fr_CA"
def_bootlang="fr_CA"
if [ -z "${keyboard}" ]; then
  def_keyboard="ca"
  keyboard="ca"
fi
if [ -z "${timezone}" ]; then
  def_timezone="America/Toronto"
  timezone="America/Toronto"
fi
export def_bootlang
export bootlang
export def_keyboard
export def_timezone
export keyboard
export timezone
