lang=en
bootlang="lang=en_HK"
def_bootlang="en_HK"
if [ -z "${keyboard}" ]; then
  def_keyboard="us"
  keyboard="keytable=us"
fi
if [ -z "${timezone}" ]; then
  def_timezone="Asia/Hong_Kong"
  timezone="tz=Asia/Hong_Kong"
fi
export def_bootlang
export bootlang
export def_keyboard
export def_timezone
export keyboard
export timezone
