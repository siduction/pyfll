lang=en
bootlang="lang=en_US"
def_bootlang="en_US"
if [ -z "${keyboard}" ]; then
  def_keyboard="us"
  keyboard="keytable=us"
fi
if [ -z "${timezone}" ]; then
  def_timezone="America/New_York"
  timezone="tz=America/New_York"
fi
export def_bootlang
export bootlang
export def_keyboard
export def_timezone
export keyboard
export timezone
