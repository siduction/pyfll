lang=pl
bootlang="lang=pl_PL"
def_bootlang="pl_PL"
if [ -z "${keyboard}" ]; then
  def_keyboard="pl"
  keyboard="keytable=pl"
fi
if [ -z "${timezone}" ]; then
  def_timezone="Europe/Warsaw"
  timezone="tz=Europe/Warsaw"
fi
export def_bootlang
export bootlang
export def_keyboard
export def_timezone
export keyboard
export timezone
