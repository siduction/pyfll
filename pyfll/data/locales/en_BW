lang=en
bootlang="lang=en_BW"
def_bootlang="en_BW"
if [ -z "${keyboard}" ]; then
  def_keyboard="us"
  keyboard="keytable=us"
fi
if [ -z "${timezone}" ]; then
  def_timezone="Africa/Gaborone"
  timezone="tz=Africa/Gaborone"
fi
export def_bootlang
export bootlang
export def_keyboard
export def_timezone
export keyboard
export timezone
