lang=pt
bootlang="lang=pt_PT"
def_bootlang="pt_PT"
if [ -z "${keyboard}" ]; then
  def_keyboard="pt"
  keyboard="keytable=pt"
fi
if [ -z "${timezone}" ]; then
  def_timezone="Europe/Lisbon"
  timezone="tz=Europe/Lisbon"
fi
export def_bootlang
export bootlang
export def_keyboard
export def_timezone
export keyboard
export timezone
