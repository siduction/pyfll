lang=nl
bootlang="lang=nl_BE"
def_bootlang="nl_BE"
if [ -z "${keyboard}" ]; then
  def_keyboard="be"
  keyboard="keytable=be"
fi
if [ -z "${timezone}" ]; then
  def_timezone="Europe/Brussels"
  timezone="tz=Europe/Brussels"
fi
export def_bootlang
export bootlang
export def_keyboard
export def_timezone
export keyboard
export timezone
