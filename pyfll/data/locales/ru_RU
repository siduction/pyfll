lang=ru
bootlang="lang=ru_RU"
def_bootlang="ru_RU"
if [ -z "${keyboard}" ]; then
  def_keyboard="ru"
  keyboard="ru"
fi
if [ -z "${timezone}" ]; then
  def_timezone="Europe/Moscow"
  timezone="Europe/Moscow"
fi
export def_bootlang
export bootlang
export def_keyboard
export def_timezone
export keyboard
export timezone
