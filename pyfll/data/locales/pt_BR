lang=pt
bootlang="lang=pt_BR"
def_bootlang="pt_BR"
if [ -z "${keyboard}" ]; then
  def_keyboard="br"
  keyboard="keytable=br"
fi
if [ -z "${timezone}" ]; then
  def_timezone="America/Sao_Paulo"
  timezone="tz=America/Sao_Paulo"
fi
export def_bootlang
export bootlang
export def_keyboard
export def_timezone
export keyboard
export timezone
