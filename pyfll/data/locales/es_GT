lang=es
bootlang="lang=es_GT"
def_bootlang="es_GT"
if [ -z "${keyboard}" ]; then
  def_keyboard="latam"
  keyboard="keytable=latam"
fi
if [ -z "${timezone}" ]; then
  def_timezone="America/Guatemala"
  timezone="tz=America/Guatemala"
fi
export def_bootlang
export bootlang
export def_keyboard
export def_timezone
export keyboard
export timezone
