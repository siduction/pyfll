lang=es
bootlang="lang=es_PE"
def_bootlang="es_PE"
if [ -z "${keyboard}" ]; then
  def_keyboard="latam"
  keyboard="keytable=latam"
fi
if [ -z "${timezone}" ]; then
  def_timezone="America/Lima"
  timezone="tz=America/Lima"
fi
export def_bootlang
export bootlang
export def_keyboard
export def_timezone
export keyboard
export timezone
