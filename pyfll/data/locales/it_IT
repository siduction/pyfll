lang=it
bootlang="lang=it_IT"
def_bootlang="it_IT"
if [ -z "${keyboard}" ]; then
  def_keyboard="it"
  keyboard="keytable=it"
fi
if [ -z "${timezone}" ]; then
  def_timezone="Europe/Rome"
  timezone="tz=Europe/Rome"
fi
export def_bootlang
export bootlang
export def_keyboard
export def_timezone
export keyboard
export timezone
