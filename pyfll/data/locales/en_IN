lang=en
bootlang="lang=en_IN"
def_bootlang="en_IN"
if [ -z "${keyboard}" ]; then
  def_keyboard="us"
  keyboard="keytable=us"
fi
if [ -z "${timezone}" ]; then
  def_timezone="Asia/Kolkata"
  timezone="tz=Asia/Kolkata"
fi
export def_bootlang
export bootlang
export def_keyboard
export def_timezone
export keyboard
export timezone
