lang=tr
bootlang="lang=tr_CY"
def_bootlang="tr_CY"
if [ -z "${keyboard}" ]; then
  def_keyboard="tr"
  keyboard="keytable=tr"
fi
if [ -z "${timezone}" ]; then
  def_timezone="Europe/Istanbul"
  timezone="tz=Europe/Istanbul"
fi
export def_bootlang
export bootlang
export def_keyboard
export def_timezone
export keyboard
export timezone
