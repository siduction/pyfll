lang=en
bootlang="lang=en_IE"
def_bootlang="en_IE"
if [ -z "${keyboard}" ]; then
  def_keyboard="ie"
  keyboard="keytable=ie"
fi
if [ -z "${timezone}" ]; then
  def_timezone="Europe/Dublin"
  timezone="tz=Europe/Dublin"
fi
export def_bootlang
export bootlang
export def_keyboard
export def_timezone
export keyboard
export timezone
