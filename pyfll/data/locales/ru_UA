lang=ru
bootlang="lang=ru_UA"
def_bootlang="ru_UA"
if [ -z "${keyboard}" ]; then
  def_keyboard="ru"
  keyboard="keytable=ru"
fi
if [ -z "${timezone}" ]; then
  def_timezone="Europe/Kiev"
  timezone="tz=Europe/Kiev"
fi
export def_bootlang
export bootlang
export def_keyboard
export def_timezone
export keyboard
export timezone
