lang=es
bootlang="lang=es_EC"
def_bootlang="es_EC"
if [ -z "${keyboard}" ]; then
  def_keyboard="latam"
  keyboard="keytable=latam"
fi
if [ -z "${timezone}" ]; then
  def_timezone="America/Guayaquil"
  timezone="tz=America/Guayaquil"
fi
export def_bootlang
export bootlang
export def_keyboard
export def_timezone
export keyboard
export timezone
