lang=es
bootlang="lang=es_NI"
def_bootlang="es_NI"
if [ -z "${keyboard}" ]; then
  def_keyboard="latam"
  keyboard="keytable=latam"
fi
if [ -z "${timezone}" ]; then
  def_timezone="America/Managua"
  timezone="tz=America/Managua"
fi
export def_bootlang
export bootlang
export def_keyboard
export def_timezone
export keyboard
export timezone
