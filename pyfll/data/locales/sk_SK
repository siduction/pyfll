lang=sk
bootlang="lang=sk_SK"
def_bootlang="sk_SK"
if [ -z "${keyboard}" ]; then
  def_keyboard="sk"
  keyboard="keytable=sk"
fi
if [ -z "${timezone}" ]; then
  def_timezone="Europe/Bratislava"
  timezone="tz=Europe/Bratislava"
fi
export def_bootlang
export bootlang
export def_keyboard
export def_timezone
export keyboard
export timezone
