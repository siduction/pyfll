lang=en
bootlang="lang=en_CA"
def_bootlang="en_CA"
if [ -z "${keyboard}" ]; then
  def_keyboard="us"
  keyboard="keytable=us"
fi
if [ -z "${timezone}" ]; then
  def_timezone="America/Toronto"
  timezone="tz=America/Toronto"
fi
export def_bootlang
export bootlang
export def_keyboard
export def_timezone
export keyboard
export timezone
